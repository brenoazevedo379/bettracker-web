generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bet {
  id        String   @id @default(cuid())
  selecao   String
  odd       Float
  valor     Float
  casa      String
  esporte   String
  status    String   @default("PENDENTE")
  retorno   Float?
  telefone  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}